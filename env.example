# ── AI (Etap 2 — ocena opłacalności) ──────────────────────────────────────
PROVIDER=groq
# jeśli PROVIDER=groq -> klucz z console.groq.com/keys
# jeśli PROVIDER=gemini -> klucz z aistudio.google.com/apikey
MAIN_API_KEY=
MAIN_MODEL=llama-3.3-70b-versatile

# ── Groq (Etap 1 — szybki klasyfikator typu, opcjonalny) ──────────────────
# Puste pole = etap 1 wyłączony, wszystko leci od razu do etapu 2
GROQ_CLASSIFIER_KEY=

# ── Discord ────────────────────────────────────────────────────────────────
DISCORD_WEBHOOK_URL=
DISCORD_THREAD_ID=
DISCORD_UNCERTAIN_WEBHOOK_URL=

# ── Strategia ──────────────────────────────────────────────────────────────
MIN_PROFIT=20
MAX_PER_CYCLE=25
MIN_UNCERTAIN_PRICE=500

# Opcjonalnie: własna lista słów odrzucających (rozdzielona przecinkami), zastępuje domyślną
# FILTER_KEYWORDS=Rennrad, Gravel, ...

# Opcjonalnie: baza wiedzy o cenach — jedna notatka na linię
# PRICE_KNOWLEDGE=Sprzedałem Canyon Torque za 1200 PLN
#Kupiłem Rose The Bruce za 500€, sprzedałem za 900€

# ── Bezpieczeństwo ─────────────────────────────────────────────────────────
# Losowy ciąg znaków — pozwala ręcznie wywołać /api/cron spoza Vercel Cron (opcjonalne)
CRON_SECRET=
# Hasło do przycisku "Uruchom teraz" w panelu — WYMAGANE jeśli chcesz korzystać z ręcznego triggera
MANUAL_TRIGGER_SECRET=

# ── Upstash Redis (te dwie zmienne dodaje Vercel automatycznie po podłączeniu integracji) ──
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
